sub1=float(input('bengali marks:'))
sub2=float(input('english marks:'))
sub3=float(input('math marks:'))

total=sub1+sub2+sub3
percentage=total/3

print('Total marks=',total)
print('Percentage=',percentage)

if percentage>=90:
	print('Grade:A+')
elif percentage>=80:
	print('Grade:A')
elif percentage>=70:
	print('Grade:B')
elif percentage>=60:
	print('Grade:C')
elif percentage>=50:
	print('Grade:D')

else:
	print('Grade:Fail')
